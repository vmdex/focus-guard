<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="FocusGuard.Clock.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FocusGuard.Clock.App"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="FocusGuard.Clock.App">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <NavigationView
            x:Name="RootNavigationView"
            CompactPaneLength="56"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="True"
            OpenPaneLength="280"
            PaneDisplayMode="Auto"
            PaneTitle="Focus Guard"
            SelectionChanged="RootNavigationView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem
                    x:Name="FocusSessionNavigationItem"
                    Content="Focus session"
                    Tag="FocusSession">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Clock" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.PaneHeader>
                <SymbolIcon
                    Symbol="Admin"
                    Width="20"
                    Height="20"
                    Margin="0,0,8,0" />
            </NavigationView.PaneHeader>

            <Grid>
            <ScrollViewer
                x:Name="FocusSessionPage"
                Padding="32">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="24" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="8">
                        <TextBlock
                            Text="Focus Guard Clock"
                            FontSize="28"
                            FontWeight="SemiBold" />
                        <TextBlock
                            Text="Developer timer prototype"
                            FontSize="14"
                            Opacity="0.72" />
                    </StackPanel>

                    <Grid
                        Grid.Row="2"
                        RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Padding="16"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Focus" Opacity="0.72" />
                                    <TextBlock
                                        x:Name="DeveloperFocusCountTextBlock"
                                        FontSize="24"
                                        FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>

                            <Border
                                Grid.Column="1"
                                Padding="16"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Breaks" Opacity="0.72" />
                                    <TextBlock
                                        x:Name="DeveloperBreakCountTextBlock"
                                        FontSize="24"
                                        FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>

                            <Border
                                Grid.Column="2"
                                Padding="16"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Used" Opacity="0.72" />
                                    <TextBlock
                                        x:Name="DeveloperUsedDurationTextBlock"
                                        FontSize="24"
                                        FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>

                            <Border
                                Grid.Column="3"
                                Padding="16"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Unused" Opacity="0.72" />
                                    <TextBlock
                                        x:Name="DeveloperUnusedDurationTextBlock"
                                        FontSize="24"
                                        FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <TextBlock
                            x:Name="ErrorTextBlock"
                            Grid.Row="3"
                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                            TextWrapping="WrapWholeWords"
                            Visibility="Collapsed" />

                        <Border
                            Grid.Row="1"
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid RowSpacing="16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Spacing="4">
                                        <TextBlock
                                            Text="Current timer"
                                            FontSize="18"
                                            FontWeight="SemiBold" />
                                        <TextBlock
                                            x:Name="DeveloperTimerStatusTextBlock"
                                            Opacity="0.72" />
                                    </StackPanel>

                                    <TextBlock
                                        x:Name="DeveloperRemainingTimeTextBlock"
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        FontSize="32"
                                        FontWeight="SemiBold" />
                                </Grid>

                                <Grid
                                    Grid.Row="1"
                                    ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Stage" Opacity="0.72" />
                                        <TextBlock
                                            x:Name="DeveloperCurrentStageTextBlock"
                                            FontWeight="SemiBold" />
                                    </StackPanel>

                                    <StackPanel
                                        Grid.Column="1"
                                        Spacing="4">
                                        <TextBlock Text="Focus elapsed" Opacity="0.72" />
                                        <TextBlock
                                            x:Name="DeveloperFocusElapsedTextBlock"
                                            FontWeight="SemiBold" />
                                    </StackPanel>

                                    <StackPanel
                                        Grid.Column="2"
                                        Spacing="4">
                                        <TextBlock Text="Total elapsed" Opacity="0.72" />
                                        <TextBlock
                                            x:Name="DeveloperTotalElapsedTextBlock"
                                            FontWeight="SemiBold" />
                                    </StackPanel>
                                </Grid>

                                <Grid
                                    Grid.Row="2"
                                    ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="220" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        Text="Total duration (min)"
                                        VerticalAlignment="Center" />

                                    <NumberBox
                                        x:Name="TotalDurationBox"
                                        Grid.Column="1"
                                        Minimum="1"
                                        SmallChange="15"
                                        LargeChange="15"
                                        SpinButtonPlacementMode="Inline"
                                        ValueChanged="SettingsNumberBox_ValueChanged" />
                                </Grid>

                                <CheckBox
                                    Grid.Row="3"
                                    x:Name="SkipBreaksCheckBox"
                                    Content="Skip breaks"
                                    Checked="SettingsInput_Changed"
                                    Unchecked="SettingsInput_Changed" />

                                <StackPanel
                                    Grid.Row="4"
                                    Orientation="Horizontal"
                                    Spacing="8">
                                    <Button
                                        x:Name="DeveloperStartButton"
                                        Content="Start"
                                        Click="StartButton_Click" />
                                    <Button
                                        x:Name="DeveloperPauseButton"
                                        Content="Pause"
                                        Click="PauseButton_Click" />
                                    <Button
                                        x:Name="DeveloperResumeButton"
                                        Content="Resume"
                                        Click="ResumeButton_Click" />
                                    <Button
                                        x:Name="DeveloperResetButton"
                                        Content="Reset"
                                        Click="ResetButton_Click" />
                                    <TextBlock
                                        x:Name="DeveloperTimerEventTextBlock"
                                        VerticalAlignment="Center"
                                        Opacity="0.72" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border
                            Grid.Row="2"
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel Spacing="12">
                                <TextBlock
                                    Text="Dev tools"
                                    FontSize="18"
                                    FontWeight="SemiBold" />

                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock
                                        Text="Advance seconds"
                                        VerticalAlignment="Center" />

                                    <StackPanel
                                        Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                        <NumberBox
                                            x:Name="AdvanceSecondsBox"
                                            Width="180"
                                            Minimum="1"
                                            Value="10"
                                            SmallChange="1"
                                            LargeChange="10"
                                            SpinButtonPlacementMode="Inline" />
                                        <Button
                                            x:Name="AdvanceButton"
                                            Content="Advance"
                                            Click="AdvanceButton_Click" />
                                    </StackPanel>
                                </Grid>

                                <StackPanel Spacing="8">
                                    <TextBlock
                                        Text="Notifications"
                                        FontSize="16" />

                                    <StackPanel
                                        Orientation="Horizontal"
                                        Spacing="8">
                                        <Button
                                            x:Name="TestBreakNotificationButton"
                                            Content="Break"
                                            Click="TestBreakNotificationButton_Click" />
                                        <Button
                                            x:Name="TestFocusNotificationButton"
                                            Content="Focus"
                                            Click="TestFocusNotificationButton_Click" />
                                        <Button
                                            x:Name="TestFinishedNotificationButton"
                                            Content="Finished"
                                            Click="TestFinishedNotificationButton_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <ListView
                            x:Name="DeveloperStagesListView"
                            Grid.Row="4">
                            <ListView.Header>
                                <TextBlock
                                    Text="Stages"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Margin="0,0,0,8" />
                            </ListView.Header>
                        </ListView>
                </Grid>
                </Grid>
            </ScrollViewer>

            <ScrollViewer
                x:Name="SettingsPage"
                Visibility="Collapsed"
                Padding="32">
                <StackPanel Spacing="32">
                    <TextBlock
                        Text="Settings"
                        FontSize="46"
                        FontWeight="SemiBold" />

                    <StackPanel Spacing="12">
                        <TextBlock
                            Text="Focus sessions"
                            FontSize="18"
                            FontWeight="SemiBold" />

                        <Border
                            Padding="20"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid ColumnSpacing="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <SymbolIcon
                                    Symbol="Clock"
                                    Width="24"
                                    Height="24"
                                    VerticalAlignment="Top"
                                    Margin="0,4,0,0" />

                                <StackPanel
                                    Grid.Column="1"
                                    Spacing="16">
                                    <StackPanel Spacing="4">
                                        <TextBlock
                                            Text="Focus periods"
                                            FontSize="18"
                                            FontWeight="SemiBold" />
                                        <TextBlock
                                            Text="Adjust the lengths of your focus time and breaks."
                                            Opacity="0.72" />
                                    </StackPanel>

                                    <Grid RowSpacing="12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid ColumnSpacing="16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="220" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock
                                                Text="Focus period (minutes)"
                                                VerticalAlignment="Center" />

                                            <NumberBox
                                                x:Name="FocusPeriodBox"
                                                Grid.Column="1"
                                                Minimum="1"
                                                SmallChange="5"
                                                LargeChange="25"
                                                SpinButtonPlacementMode="Inline"
                                                ValueChanged="SettingsNumberBox_ValueChanged" />
                                        </Grid>

                                        <Grid
                                            Grid.Row="1"
                                            ColumnSpacing="16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="220" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock
                                                Text="Break period (minutes)"
                                                VerticalAlignment="Center" />

                                            <NumberBox
                                                x:Name="BreakPeriodBox"
                                                Grid.Column="1"
                                                Minimum="1"
                                                SmallChange="5"
                                                LargeChange="10"
                                                SpinButtonPlacementMode="Inline"
                                                ValueChanged="SettingsNumberBox_ValueChanged" />
                                        </Grid>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="12">
                        <TextBlock
                            Text="Notifications"
                            FontSize="18"
                            FontWeight="SemiBold" />

                        <Border
                            Padding="20"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <Grid ColumnSpacing="20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <SymbolIcon
                                    Symbol="Message"
                                    Width="24"
                                    Height="24"
                                    VerticalAlignment="Top"
                                    Margin="0,4,0,0" />

                                <StackPanel
                                    Grid.Column="1"
                                    Spacing="16">
                                    <StackPanel Spacing="4">
                                        <TextBlock
                                            Text="Timer notifications"
                                            FontSize="18"
                                            FontWeight="SemiBold" />
                                        <TextBlock
                                            Text="Control transition alerts and their sound."
                                            Opacity="0.72" />
                                    </StackPanel>

                                    <Grid RowSpacing="12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid ColumnSpacing="16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock
                                                Text="Show notifications"
                                                VerticalAlignment="Center" />

                                            <TextBlock
                                                x:Name="ShowNotificationsStateTextBlock"
                                                Grid.Column="1"
                                                VerticalAlignment="Center" />

                                            <ToggleSwitch
                                                x:Name="ShowNotificationsToggleSwitch"
                                                Grid.Column="2"
                                                MinWidth="0"
                                                Width="48"
                                                OnContent=""
                                                OffContent=""
                                                Toggled="SettingsInput_Changed" />
                                        </Grid>

                                        <Grid
                                            Grid.Row="1"
                                            ColumnSpacing="16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock
                                                Text="Play notification sound"
                                                VerticalAlignment="Center" />

                                            <TextBlock
                                                x:Name="PlayNotificationSoundStateTextBlock"
                                                Grid.Column="1"
                                                VerticalAlignment="Center" />

                                            <ToggleSwitch
                                                x:Name="PlayNotificationSoundToggleSwitch"
                                                Grid.Column="2"
                                                MinWidth="0"
                                                Width="48"
                                                OnContent=""
                                                OffContent=""
                                                Toggled="SettingsInput_Changed" />
                                        </Grid>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
            </Grid>
        </NavigationView>

        <Grid
            x:Name="WindowDragArea"
            Height="32"
            Margin="280,0,140,0"
            VerticalAlignment="Top"
            Background="Transparent"
            Canvas.ZIndex="10" />
    </Grid>
</Window>
