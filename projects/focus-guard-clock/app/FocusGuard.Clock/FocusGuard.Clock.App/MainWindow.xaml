<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="FocusGuard.Clock.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FocusGuard.Clock.App"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="FocusGuard.Clock.App">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="24" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="8">
            <TextBlock
                Text="Focus Guard Clock"
                FontSize="28"
                FontWeight="SemiBold" />
            <TextBlock
                Text="Developer timer prototype"
                FontSize="14"
                Opacity="0.72" />
        </StackPanel>

        <Grid Grid.Row="2" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="16">
                <NumberBox
                    x:Name="TotalDurationBox"
                    Header="Total duration (minutes)"
                    Minimum="1"
                    SmallChange="5"
                    LargeChange="25"
                    SpinButtonPlacementMode="Inline" />

                <NumberBox
                    x:Name="FocusPeriodBox"
                    Header="Focus period (minutes)"
                    Minimum="0"
                    SmallChange="5"
                    LargeChange="25"
                    SpinButtonPlacementMode="Inline" />

                <NumberBox
                    x:Name="BreakPeriodBox"
                    Header="Break period (minutes)"
                    Minimum="0"
                    SmallChange="5"
                    LargeChange="10"
                    SpinButtonPlacementMode="Inline" />

                <CheckBox
                    x:Name="SkipBreaksCheckBox"
                    Content="Skip breaks" />

                <Button
                    Content="Calculate"
                    Click="CalculateButton_Click" />

                <TextBlock
                    x:Name="ErrorTextBlock"
                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                    TextWrapping="WrapWholeWords"
                    Visibility="Collapsed" />
            </StackPanel>

            <Grid
                Grid.Column="1"
                RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Focus" Opacity="0.72" />
                            <TextBlock
                                x:Name="DeveloperFocusCountTextBlock"
                                FontSize="24"
                                FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="1"
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Breaks" Opacity="0.72" />
                            <TextBlock
                                x:Name="DeveloperBreakCountTextBlock"
                                FontSize="24"
                                FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="2"
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Used" Opacity="0.72" />
                            <TextBlock
                                x:Name="DeveloperUsedDurationTextBlock"
                                FontSize="24"
                                FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="3"
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Unused" Opacity="0.72" />
                            <TextBlock
                                x:Name="DeveloperUnusedDurationTextBlock"
                                FontSize="24"
                                FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border
                    Grid.Row="1"
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid RowSpacing="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="4">
                                <TextBlock
                                    Text="Current timer"
                                    FontSize="18"
                                    FontWeight="SemiBold" />
                                <TextBlock
                                    x:Name="DeveloperTimerStatusTextBlock"
                                    Opacity="0.72" />
                            </StackPanel>

                            <TextBlock
                                x:Name="DeveloperRemainingTimeTextBlock"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                FontSize="32"
                                FontWeight="SemiBold" />
                        </Grid>

                        <Grid
                            Grid.Row="1"
                            ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Stage" Opacity="0.72" />
                                <TextBlock
                                    x:Name="DeveloperCurrentStageTextBlock"
                                    FontWeight="SemiBold" />
                            </StackPanel>

                            <StackPanel
                                Grid.Column="1"
                                Spacing="4">
                                <TextBlock Text="Focus elapsed" Opacity="0.72" />
                                <TextBlock
                                    x:Name="DeveloperFocusElapsedTextBlock"
                                    FontWeight="SemiBold" />
                            </StackPanel>

                            <StackPanel
                                Grid.Column="2"
                                Spacing="4">
                                <TextBlock Text="Total elapsed" Opacity="0.72" />
                                <TextBlock
                                    x:Name="DeveloperTotalElapsedTextBlock"
                                    FontWeight="SemiBold" />
                            </StackPanel>
                        </Grid>

                        <StackPanel
                            Grid.Row="2"
                            Orientation="Horizontal"
                            Spacing="8">
                            <Button
                                x:Name="DeveloperStartButton"
                                Content="Start"
                                Click="StartButton_Click" />
                            <Button
                                x:Name="DeveloperPauseButton"
                                Content="Pause"
                                Click="PauseButton_Click" />
                            <Button
                                x:Name="DeveloperResumeButton"
                                Content="Resume"
                                Click="ResumeButton_Click" />
                            <Button
                                x:Name="DeveloperResetButton"
                                Content="Reset"
                                Click="ResetButton_Click" />
                            <Button
                                x:Name="DeveloperStopButton"
                                Content="Stop"
                                Click="StopButton_Click" />
                            <TextBlock
                                x:Name="DeveloperTimerEventTextBlock"
                                VerticalAlignment="Center"
                                Opacity="0.72" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border
                    Grid.Row="2">
                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="12">
                            <TextBlock
                                Text="Dev tools"
                                FontSize="18"
                                FontWeight="SemiBold" />

                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="8">
                                <NumberBox
                                    x:Name="AdvanceSecondsBox"
                                    Header="Advance seconds"
                                    Width="180"
                                    Minimum="1"
                                    Value="10"
                                    SmallChange="1"
                                    LargeChange="10"
                                    SpinButtonPlacementMode="Inline" />
                                <Button
                                    x:Name="AdvanceButton"
                                    Content="Advance"
                                    VerticalAlignment="Bottom"
                                    Click="AdvanceButton_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <ListView
                    x:Name="DeveloperStagesListView"
                    Grid.Row="3">
                    <ListView.Header>
                        <TextBlock
                            Text="Stages"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Margin="0,0,0,8" />
                    </ListView.Header>
                </ListView>
            </Grid>
        </Grid>
    </Grid>
</Window>
